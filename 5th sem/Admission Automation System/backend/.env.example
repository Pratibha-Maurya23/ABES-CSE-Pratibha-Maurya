# MongoDB Connection
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>

# Session Secret (koi bhi random strong string)
SESSION_SECRET=your_super_secret_key_here

# Node Environment
NODE_ENV=production

# Frontend URL (Vercel/Netlify par deploy hone ke baad aayega)
FRONTEND_URL=https://your-frontend-app.vercel.app

# Port (Render automatically set karta hai, change mat karna)
PORT=8000

# Twilio (optional - WhatsApp OTP ke liye)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+14155238886
